# ─────────────────────────────────────────────────────────────
#  AVIANTA  —  Environment Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Backend (Railway) ────────────────────────────────────────
# Your RapidAPI key — server-side ONLY, never exposed to frontend
RAPIDAPI_KEY=your_rapidapi_key_here

# Backend port (Railway sets this automatically)
PORT=5000

# ── Frontend (Vercel) ────────────────────────────────────────
# URL of your deployed backend (Railway). For local dev use http://localhost:5000
VITE_API_URL=https://your-railway-app.railway.app
